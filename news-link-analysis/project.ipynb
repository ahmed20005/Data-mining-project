    "# BERT Zero-Shot Classification\n",
    "from transformers import pipeline\n",
    "from sklearn.metrics import classification_report, confusion_matrix, accuracy_score\n",
    "from tqdm import tqdm\n",
    "\n",
    "# Load data\n",
